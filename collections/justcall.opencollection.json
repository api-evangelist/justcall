{
  "opencollection": "1.0.0",
  "info": {
    "name": "JustCall REST API",
    "version": "2.1"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "Authorization",
      "value": "{{Authorization}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Calls",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List calls",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.justcall.io/v2.1/calls"
          },
          "docs": "Retrieves all calls linked to an account, with optional filters to refine the call selection (such as date range, agent, contact, or direction)."
        }
      ]
    },
    {
      "info": {
        "name": "Contacts",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Create a contact",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.justcall.io/v2.1/contacts",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Adds a new contact to the JustCall Contacts section."
        }
      ]
    },
    {
      "info": {
        "name": "SMS",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Send SMS or MMS",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.justcall.io/v2.1/texts",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Sends an SMS or MMS message via JustCall. Useful for automation and outbound messaging flows."
        }
      ]
    }
  ],
  "bundled": true
}